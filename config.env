# config.env — autoresearch project config.
# Sourced by score.sh and loop.sh on every run. Edit per project here.
#
# Each var uses ${VAR:-default} so inline env vars from the caller still
# take precedence: e.g. `APP_NAME=foo ./loop.sh` wins over the value below.

# Used as the docker image tag prefix and container name prefix.
APP_NAME="${APP_NAME:-app}"

# The branch the loop ratchets forward on every win.
MASTER_BRANCH="${MASTER_BRANCH:-main}"

# Host port to bind the smoke-test container to.
HOST_PORT="${HOST_PORT:-3000}"

# Port the container actually listens on (passed as $PORT to the container).
CONTAINER_PORT="${CONTAINER_PORT:-3000}"

# Seconds the smoke test waits for GET / to return 200 before declaring failure.
READY_TIMEOUT="${READY_TIMEOUT:-60}"

# Stop conditions — see program.md.
STOP_FAILS="${STOP_FAILS:-5}"          # halt after N consecutive same-cause FAILs
STOP_NOIMP="${STOP_NOIMP:-10}"         # halt after N consecutive non-improvements
STOP_BELOW_MB="${STOP_BELOW_MB:-30}"   # halt when current best is below this many MB
